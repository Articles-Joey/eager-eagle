# Only used by Articles Media.
NEXT_PUBLIC_CDN=sample

# Address to the default Node server. Typically only used by Articles Media.
NEXT_PUBLIC_NODE_SERVER_DISABLED=sample
NEXT_PUBLIC_NODE_SERVER=sample

# Used for GitHub button and Credits modal
NEXT_PUBLIC_OWNER=Articles-Joey
NEXT_PUBLIC_REPO=eager-eagle

NEXT_PUBLIC_GAME_NAME=Eager Eagle
NEXT_PUBLIC_GAME_KEY=eager-eagle
NEXT_PUBLIC_GAME_PORT=3049

# CDN or Local - Keep as Local unless you have set up a CDN. Typically only used by Articles Media.
NEXT_PUBLIC_MODEL_SOURCE=Local

# Opt in to enable scoreboard and ad related features. Typically only used by Articles Media.
NEXT_PUBLIC_ENABLE_ARTICLES=false